DATABASE_URL=postgres://user:password@localhost:5432/atla

# Admin route protection
ADMIN_ACCESS_PASSWORD=change-me

# Separate Sanity journal content source.
# Used both by the runtime API and by the Vercel build step that prerenders journal SEO pages.
SANITY_JOURNAL_PROJECT_ID=your-project-id
SANITY_JOURNAL_DATASET=production
SANITY_JOURNAL_API_VERSION=2026-03-12
SANITY_JOURNAL_READ_TOKEN=
